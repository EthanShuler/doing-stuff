# Copy to `.env.local` and fill in from your Supabase project:
#   Project Settings → Data API → Project URL
#   Project Settings → API Keys → anon / public key
#
# Both are PUBLIC values — they ship to the browser. Row Level Security is what
# protects your data, not these. Never put the service_role key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
